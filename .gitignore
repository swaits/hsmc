# Rust build artifacts
/target
**/target/

# Tooling output (coverage, mutation testing, profiling, mise cache)
/coverage/
/mutants.out/
/mutants.out.old/
mutation_history.json
*.profraw

# Creusot output: cargo-creusot dumps `.coma` (Coma IR) files here for
# Why3 to read. Regenerated on every `just verify` run.
/verif/

# Creusot/why3find config — `cargo creusot init` regenerates with
# defaults appropriate to the local prover install. The `profile`
# section caches per-machine prover timings that aren't portable.
# `just verify` regenerates if missing.
/why3find.json
# why3find's per-run cache directory.
/.why3find/

# Project-local Python venv created by mise's `_.python.venv` config.
**/.venv/

# Local Claude Code config (per-host overrides)
.claude/settings.local.json

# OS / editor
.DS_Store
*.swp
